# Flask セッション署名用キー
# 生成: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# ログイン画面で要求する共有パスワード（未設定だとログイン不可になるので必ず設定する）
APP_PASSWORD=change-this-to-a-shared-password

# コンテナが作るファイルのオーナーをホストユーザーに合わせる
# 確認: id -u  /  id -g
APP_UID=1000
APP_GID=1000
